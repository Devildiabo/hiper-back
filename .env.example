# ============================================================
# HIPERSELECT BACKEND — .env.example
# ============================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais (NUNCA commite o .env)
# 3. Gere o JWT_SECRET com: openssl rand -base64 48
# ============================================================

# ============================================================
# SERVIDOR
# ============================================================
PORT=3005
NODE_ENV=development

# ============================================================
# SUPABASE (PostgreSQL)
# ============================================================
# URL do projeto — painel do Supabase > Settings > API
SUPABASE_URL=https://<project-id>.supabase.co

# Service Role Key — painel do Supabase > Settings > API
# ATENÇÃO: bypassa RLS completamente. Nunca exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key-aqui>

# Anon Key — usada para autenticação de usuários via Supabase Auth
SUPABASE_ANON_KEY=<sua-anon-key-aqui>

# ============================================================
# OPENAI
# ============================================================
# Chave da API — platform.openai.com > API Keys
OPENAI_API_KEY=sk-<sua-openai-api-key-aqui>

# ============================================================
# JWT (Autenticação)
# ============================================================
# Gere com: openssl rand -base64 48
# Mínimo: 32 caracteres aleatórios. NÃO use strings previsíveis.
JWT_SECRET=<gere-com-openssl-rand-base64-48>

# Expiração do token (ex: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# ============================================================
# REDIS / BULLMQ
# ============================================================
# Habilitar fila de tarefas BullMQ
USE_BULLMQ=false

# Opção 1 (recomendada para Railway): URL pública
# REDIS_PUBLIC_URL=redis://default:<password>@<host>:<port>

# Opção 2: URL interna (Railway internal network)
# REDIS_URL=redis://default:<password>@<internal-host>:6379

# Opção 3: Configuração separada (host/port/password)
# REDIS_HOST=<seu-redis-host>
# REDIS_PORT=6379
# REDIS_PASSWORD=<sua-redis-password>
# REDIS_USER=default

# ============================================================
# WHATSAPP
# ============================================================
# Caminho de persistência da sessão Baileys
# Em produção com container efêmero, USE_HYBRID_AUTH_CACHE=true é obrigatório
WHATSAPP_SESSION_PATH=./sessions

# Cache híbrido: RAM → Redis → Supabase (OBRIGATÓRIO em produção)
USE_HYBRID_AUTH_CACHE=false

# Número de telefone para alertas de desconexão (opcional)
# WHATSAPP_ALERT_PHONE_NUMBER=5548999999999

# URL de webhook para alertas (opcional)
# WHATSAPP_ALERT_WEBHOOK_URL=https://hooks.example.com/whatsapp-alert

# Habilitar alertas de desconexão (default: true)
WHATSAPP_ALERT_ENABLED=true

# ============================================================
# CACHE DE MEMÓRIA (Conversas)
# ============================================================
MEMORY_CACHE_ENABLED=true
MEMORY_CACHE_TTL_SECONDS=60

# ============================================================
# SUPABASE STORAGE (para mídia do WhatsApp)
# ============================================================
# Bucket público de storage — preencher com o nome do bucket
SUPABASE_STORAGE_BUCKET=whatsapp

# ============================================================
# NOTAS DE SEGURANÇA
# ============================================================
# ✅ Este arquivo é seguro para commitar (contém apenas placeholders)
# ❌ NUNCA commite o arquivo .env (está no .gitignore)
# ❌ NUNCA exponha SUPABASE_SERVICE_ROLE_KEY no frontend
# ✅ Em produção, injete as vars via painel da plataforma (Railway, etc.)
